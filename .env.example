# Copia este archivo a .env.local y rellena con tus datos reales
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
OPENAI_API_KEY=sk-...
NEXT_PUBLIC_APP_URL=https://tu-app.up.railway.app
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role

# Solo para npm run migrate:instagram (contraseña de Database en Supabase)
SUPABASE_DB_PASSWORD=tu_database_password

# Meta / Instagram API (Continuar con Instagram)
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
NEXT_PUBLIC_INSTAGRAM_APP_ID=your_instagram_app_id
# Fallback legacy:
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
